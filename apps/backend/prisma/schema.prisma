// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id     @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
  avatars   Avatar[]
  avatarVideos AvatarVideo[]
}

model Avatar {
  id         String    @id   @default(uuid())
  userId     String 
  name       String
  AvatarImages AvatarImage[]
  AvatarVideoReferences AvatarVideoReference[]
  user       User     @relation(fields: [userId], references: [id])
}

model AvatarImage {
  id         String    @id   @default(uuid())
  avatarId   String
  type       AvatarImageType
  avatar     Avatar     @relation(fields: [avatarId], references: [id])
}

enum AvatarImageType {
  User
  Model
}

model AvatarVideo {
  id            String    @id @default(uuid())
  userId         String
  prompt        String
  startFrame    String?
  endFrame      String?
  duration      Int
  width         Int
  height        Int
  status        AvatarVideoStatus
  AvatarVideoReferences   AvatarVideoReference[]
  user          User     @relation(fields: [userId], references: [id])
}

enum AvatarVideoStatus {
  Processing
  Completed
  Failed
}

model AvatarVideoReference {
  id              String   @id   @default(uuid())
  avatarVideoId   String
  avatarId        String
  avatarVideo     AvatarVideo     @relation(fields: [avatarVideoId], references: [id])
  avatar          Avatar          @relation(fields: [avatarId], references: [id])
}